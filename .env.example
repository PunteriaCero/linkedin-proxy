# LinkedIn Credentials (Cookies)
# Obtén estos valores de: LinkedIn DevTools > Application > Cookies
LINKEDIN_LI_AT=your_li_at_cookie_here
LINKEDIN_JSESSIONID=your_jsessionid_here

# n8n Webhook
# URL donde n8n recibirá los mensajes de LinkedIn
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/linkedin-sync

# Server Configuration (Opcional)
HOST=0.0.0.0
PORT=8000
DEBUG=false
